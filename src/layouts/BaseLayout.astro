---
import '../styles/global.css';
import { siteConfig, type SiteLanguage } from '../config';

interface Props {
	lang: SiteLanguage;
	title: string;
	description: string;
	canonicalPath: string;
	enPath: string;
	ruPath: string;
	isHome?: boolean;
}

const { lang, title, description, canonicalPath, enPath, ruPath, isHome = false } = Astro.props;
const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const enUrl = new URL(enPath, siteConfig.siteUrl).toString();
const ruUrl = new URL(ruPath, siteConfig.siteUrl).toString();
const ogImage = new URL('/og.png', siteConfig.siteUrl).toString();
const structuredData = isHome ? {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: siteConfig.name,
	applicationCategory: 'LifestyleApplication',
	operatingSystem: 'iOS, iPadOS',
	description,
	url: siteConfig.siteUrl,
	...(siteConfig.appStoreUrl ? { installUrl: siteConfig.appStoreUrl } : {}),
} : null;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f8f7f5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#070708" media="(prefers-color-scheme: dark)" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="ru" href={ruUrl} />
		<link rel="alternate" hreflang="x-default" href={enUrl} />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="PhotoDays" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : 'en_US'} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<title>{title}</title>
		{structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
	</head>
	<body>
		<a class="skip-link" href="#main-content">{lang === 'ru' ? 'Перейти к содержимому' : 'Skip to content'}</a>
		<slot />
	</body>
</html>
